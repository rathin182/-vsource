generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ROLES {
  ADMIN
  BRANCH_MANAGER
  COUNSELOR
  FRONT_DESK
  RECEPTIONIST
}

enum STATUS {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum StudentStatus {
  ACTIVE
  ON_HOLD
  ENROLLED
  VISA_GRANTED
  DOCUMENTS_PENDING
}

enum ApplicationStage {
  INQUIRY
  DOCUMENTS
  APPLIED
  OFFER
  VISA
  ENROLLED
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
}

enum StudentStage {
  LEAD_CREATED
  APPLICATION_SUBMITTED
  OFFER_RECEIVED
  DEPOSIT_PAID
  INTERVIEW_COMPLETED
  CAS_RECEIVED
  VISA_APPLIED
  VISA_APPROVED
}

enum VisaStatus {
  NOT_STARTED
  APPLIED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum RemarkType {
  NOTE
  FOLLOW_UP
  DOCUMENT
  CALL
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Qualification {
  HIGH_SCHOOL
  DIPLOMA
  BACHELORS
  MASTERS
  PHD
}

enum IntakeSeason {
  SPRING
  SUMMER
  FALL
  WINTER
}

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique
  password String
  phone String

  role   ROLES
  status STATUS @default(ACTIVE)

  lastLogin DateTime?

  // User belongs to branches
  branches Branch[] @relation("BranchUsers")

  // User manages branches
  managedBranches Branch[] @relation("BranchManager")

  leads        Lead[]
  students     Student[]
  applications Application[]
  remark       Remark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Branch {
  id   String @id @default(uuid())
  name String
  city String

  managerId String?
  manager   User?   @relation("BranchManager", fields: [managerId], references: [id])

  users User[] @relation("BranchUsers")

  staffCount    Int     @default(0)
  studentsCount Int     @default(0)
  revenue       Decimal @db.Decimal(12, 2)

  leads    Lead[]
  students Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("branches")
}

model Lead {
  id String @id @default(uuid())

  // Personal Information
  firstName      String
  lastName       String?
  email          String  @unique
  phone          String  @unique
  alternatePhone String?

  dob            DateTime?
  gender         Gender?

  // Academic Information
  qualification  Qualification?

  percentage     Float?
  passingYear    Int?

  ieltsScore     Float?
  pteScore       Float?
  toeflScore     Float?
  duolingoScore  Float?

  // Study Preferences
  preferredCountry String?
  preferredCourse  String?

  intakeSeason     IntakeSeason?
  intakeYear       Int?

  budget           Decimal? @db.Decimal(12,2)

  // Lead Information
  source           String
  referralSource   String?

  status           LeadStatus @default(NEW)

  country          String?

  branchId         String
  counselorId      String

  branch           Branch @relation(fields: [branchId], references: [id])
  counselor        User   @relation(fields: [counselorId], references: [id])

  // Notes
  notes            String?

  // Conversion
  student          Student?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("leads")
}

model Student {
  id String @id

  name  String
  email String @unique
  phone String @unique

  dob DateTime

  country String
  program String
  intake  String

  admissionDate DateTime?

  applicationType String?

  passportNumber String? @unique

  englishRequirement String?

  currentStage StudentStage @default(LEAD_CREATED)

  status   StudentStatus @default(ACTIVE)
  progress Int           @default(0)

  leadId      String? @unique
  counselorId String?
  branchId    String?

  lead      Lead?   @relation(fields: [leadId], references: [id])
  counselor User?   @relation(fields: [counselorId], references: [id])
  branch    Branch? @relation(fields: [branchId], references: [id])

  applications Application[]
  loans        LoanInquiry[]
  visaDetail   VisaDetail?
  remarks      Remark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("students")
}

model VisaDetail {
  id String @id @default(uuid())

  studentId String @unique

  visaType String?

  status VisaStatus @default(NOT_STARTED)

  applicationDate DateTime?
  biometricsDate  DateTime?
  interviewDate   DateTime?

  approvalDate    DateTime?
  rejectionReason String?

  visaNumber String?

  expiryDate DateTime?

  student Student @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("visa_details")
}

model Remark {
  id String @id @default(uuid())

  studentId String

  title   String?
  message String

  type RemarkType @default(NOTE)

  createdById String?

  student Student @relation(fields: [studentId], references: [id])

  createdBy User? @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@map("remarks")
}

model Application {
  id String @id

  studentId   String
  counselorId String

  university String
  program    String
  intake     String

  stage ApplicationStage @default(INQUIRY)

  student   Student @relation(fields: [studentId], references: [id])
  counselor User    @relation(fields: [counselorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("applications")
}

model LoanInquiry {
  id String @id

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  bank   String
  amount Decimal @db.Decimal(12, 2)

  status LoanStatus @default(PENDING)

  emi Decimal @db.Decimal(10, 2)

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("loan_inquiries")
}
