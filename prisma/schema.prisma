generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ROLES {
  ADMIN
  BRANCH_MANAGER
  COUNSELLOR
  FRONT_DESK
  RECEPTIONIST
}

enum STATUS {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum LeadStage {
  INQUIRY
  DOCUMENTS
  APPLIED
  OFFER
  VISA
  ENROLLED
}

enum ApplicationStage {
  INQUIRY
  DOCUMENTS
  APPLIED
  OFFER
  VISA
  ENROLLED
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  DISBURSED
}

enum StudentStage {
  LEAD_CREATED
  APPLICATION_SUBMITTED
  OFFER_RECEIVED
  DEPOSIT_PAID
  INTERVIEW_COMPLETED
  CAS_RECEIVED
  VISA_APPLIED
  VISA_APPROVED
}

// enum VisaStatus {
//   NOT_STARTED
//   APPLIED
//   UNDER_REVIEW
//   APPROVED
//   REJECTED
// }

enum RemarkType {
  NOTE
  FOLLOW_UP
  DOCUMENT
  CALL
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Qualification {
  HIGH_SCHOOL
  DIPLOMA
  BACHELORS
  MASTERS
  PHD
}

enum IntakeSeason {
  SPRING
  SUMMER
  FALL
  WINTER
}

model User {
  id String @id @default(uuid())

  name     String
  email    String  @unique
  password String
  phone    String?

  monthlyTarget Int?     @default(0)
  branches      Branch[]

  leadAssignments        LeadCounselor[]
  leadCounselorsAssigned LeadCounselor[] @relation("LeadAssignedBy")

  mbbsLeadAssignments        MbbsLeadCounselor[]
  mbbsLeadCounselorsAssigned MbbsLeadCounselor[] @relation("MbbsLeadAssignedBy")

  students Student[] @relation("CounselorStudents")

  studentTimelines StudentTimeline[] @relation("StudentTimelineCreatedBy")

  leadTimelinesCreated LeadTimeline[] @relation("LeadTimelineCreatedBy")
  leadTimelinesUpdated LeadTimeline[] @relation("LeadTimelineUpdatedBy")

  mbbsTimelinesCreated MbbsLeadTimeline[] @relation("MbbsTimelineCreatedBy")
  mbbsTimelinesUpdated MbbsLeadTimeline[] @relation("MbbsTimelineUpdatedBy")

  leadsCreated Lead[] @relation("LeadCreatedBy")
  leadsUpdated Lead[] @relation("LeadUpdatedBy")

  mbbsLeadsCreated MbbsLead[] @relation("MbbsLeadCreatedBy")
  mbbsLeadsUpdated MbbsLead[] @relation("MbbsLeadUpdatedBy")

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  remarks      Remark[]
  applications Application[]
  lead         Lead[]
}

model Role {
  id String @id @default(uuid())

  name String @unique

  description String?

  isSystem Boolean @default(false)

  users User[]

  modulePermissions RoleModulePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoleModulePermission {
  roleId String

  moduleId String

  canCreate Boolean @default(false)

  canRead Boolean @default(false)

  canUpdate Boolean @default(false)

  canDelete Boolean @default(false)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([roleId, moduleId])
}

model Module {
  id String @id @default(uuid())

  name String

  code String @unique

  icon String?

  sortOrder Int @default(0)

  isActive Boolean @default(true)

  modulePermissions RoleModulePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id String @id @default(uuid())

  // Personal Information
  branch             Branch    @relation(fields: [branchId], references: [id])
  applicationDate    DateTime?
  studentName        String?   @default("Unnkown")
  fatherName         String?
  email              String
  phone              String
  dob                DateTime?
  passport           String?
  passportExpireDate DateTime?
  gender             Gender?
  source             String?

  nextFollowup DateTime?
  // Academic Information 
  tenthPassingYear       Int?
  tenthPassingPercentage Float?
  twelfthPercentage      Float?
  twelfthYearOfPassing   Int?

  bachelorsCourse         String?
  bachelorsUniversityName String?
  bachelorsPercentage     Float?
  bachelorsYearOfPassing  Int?
  ieltsScore              Int?

  backlogs       Int?
  workExperience String?
  gapsIfAny      String?

  // i d k 
  greGmatScore           Float?
  quantitativeScore      Float?
  verbalScore            Float?
  analyticalWritingScore Float?

  englishTestType String?

  listeningScore Float?
  writingScore   Float?
  readingScore   Float?
  speakingScore  Float?

  // prefrence
  preferredCountry String?
  preferredIntake  String?
  preferredCourse  String?
  preferredTiers   String[] @default([])

  leadStage LeadStage @default(INQUIRY)

  intakeSeason IntakeSeason?
  budget       Decimal?      @db.Decimal(12, 2)

  status LeadStatus @default(NEW)

  country String?

  visaStage StudentVisaStage @default(APPLICATION_SUBMITTED)

  admissionDate             DateTime?
  currentStage              Studentstage      @default(PURSUING)
  englishWaiverType         EnglishWaiverType @default(NONE)
  applicationType           ApplicationType   @default(BACHELOR)
  immigrationPortalPassword String?
  depositDeadline           DateTime?
  casDeadline               DateTime?
  universityStart           DateTime?

  branchId    String
  counselorId String?

  counselor User? @relation(fields: [counselorId], references: [id])

  createdById String?
  updatedById String?

  createdBy User? @relation("LeadCreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("LeadUpdatedBy", fields: [updatedById], references: [id])

  // Notes
  notes String?

  // Conversion
  student        Student?
  timelines      LeadTimeline[]
  counselors     LeadCounselor[]
  docs           Doc[]
  loanInquiries  LoanInquiry[]
  remarks        Remark[]
  studentCourses StudentCourses[]
  visaDetail     VisaDetail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}

model VisaDetail {
  id String @id @default(uuid())
  // studentId String @unique

  depositDeadline     DateTime?
  depositStatus       DepositStatus?
  ihsStatus           IhsStatus?
  visaFeeStatus       VisaFeeStatus?
  casDeadline         DateTime?
  casStatus           CasStatus?
  status              VisaStatus @default(NOT_STARTED)
  universityStartDate DateTime?

  // student Student @relation(fields: [studentId], references: [id])
  leadId String? @unique
  lead   Lead?   @relation(fields: [leadId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("visa_details")
}

enum DepositStatus {
  PENDING
  PAID
  REFUNDED
  WAIVED
}

enum IhsStatus {
  PENDING
  PAID
  NOT_REQUIRED
}

enum VisaFeeStatus {
  PENDING
  PAID
  NOT_REQUIRED
}

enum CasStatus {
  NOT_STARTED
  DOCUMENTS_PENDING
  UNDER_REVIEW
  RECEIVED
  REJECTED
  NOT_REQUIRED
}

enum VisaStatus {
  NOT_STARTED
  DOCUMENTS_PENDING
  APPLIED
  DECISION_PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model Remark {
  id String @id @default(uuid())

  // studentId String

  title   String?
  message String

  type RemarkType @default(NOTE)

  createdById String?
  createdBy User? @relation(fields: [createdById], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  createdAt DateTime @default(now())

  @@map("remarks")
}

model Application {
  id String @id

  studentId   String
  counselorId String

  university String
  program    String
  intake     String

  stage ApplicationStage @default(INQUIRY)

  student   Student @relation(fields: [studentId], references: [id])
  counselor User    @relation(fields: [counselorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("applications")
}

model LoanInquiry {
  id String @id @default(uuid())

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  leadId String? @unique
  lead   Lead?   @relation(fields: [leadId], references: [id])

  assignee String?
  bank     String
  amount   Decimal @db.Decimal(12, 2)

  status LoanStatus @default(PENDING)

  emi Decimal @db.Decimal(10, 2)

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("loan_inquiries")
}

model LeadCounselor {
  id String @id @default(uuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  counselorId String
  counselor   User   @relation(fields: [counselorId], references: [id])

  assignedAt DateTime @default(now())

  assignedById String?
  assignedBy   User?   @relation("LeadAssignedBy", fields: [assignedById], references: [id])

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([leadId, counselorId])
}

model MbbsLeadCounselor {
  id String @id @default(uuid())

  mbbsLeadId String
  mbbsLead   MbbsLead @relation(fields: [mbbsLeadId], references: [id], onDelete: Cascade)

  counselorId String
  counselor   User   @relation(fields: [counselorId], references: [id])

  assignedAt DateTime @default(now())

  assignedById String?
  assignedBy   User?   @relation("MbbsLeadAssignedBy", fields: [assignedById], references: [id])

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([mbbsLeadId, counselorId])
}

model LeadTimeline {
  id String @id @default(uuid())

  leadId String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  description  String
  nextFollowup DateTime?

  createdById String?
  updatedById String?

  createdBy User? @relation("LeadTimelineCreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("LeadTimelineUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

model MbbsLeadTimeline {
  id String @id @default(uuid())

  mbbsLeadId String

  mbbsLead MbbsLead @relation(fields: [mbbsLeadId], references: [id])

  description  String
  nextFollowup DateTime?

  createdById String?
  updatedById String?

  createdBy User? @relation("MbbsTimelineCreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("MbbsTimelineUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mbbsLeadId])
}

enum MbbsLeadStatus {
  new
  contacted
  qualified
  admitted
  enrolled
  lost
}

model MbbsLead {
  id String @id @default(uuid())

  leadNumber String @unique

  counsellingDate DateTime?

  studentName String?
  fatherName  String?

  mobileNumber String?
  emailId      String?

  address String?

  state String?
  city  String?

  passport           String?
  passportExpireDate DateTime?

  source String?

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  twelfthCollegeName String?
  twelfthMarks       Float?

  neetMarks Float?

  timelines MbbsLeadTimeline[]

  ept String?

  listeningScore Float?
  readingScore   Float?
  writingScore   Float?
  speakingScore  Float?

  preferredCountry    String?
  preferredIntake     String?
  preferredUniversity String?
  preferredCourse     String?

  remarks String?

  counselors MbbsLeadCounselor[]

  status MbbsLeadStatus @default(new)

  nextFollowup DateTime?

  createdById String?
  updatedById String?

  createdBy User? @relation("MbbsLeadCreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("MbbsLeadUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StudentStatus {
  active
  visa_process
  loan_process
  admitted
  enrolled
  completed
  dropped
}

enum Studentstage {
  GRADUATE
  PURSUING
}

enum StudentVisaStage {
  LEAD_CREATED
  APPLICATION_SUBMITTED
  OFFER_RECEIVED
  DEPOSIT_PAID
  INTERVIEW_COMPLETED
  CAS_RECEIVED
  VISA_APPLIED
  VISA_APPROVED
}

enum EnglishWaiverType {
  NONE
  CLASS_12_ENGLISH
  MOI
}

enum ApplicationType {
  BACHELOR
  MASTER
  PHD
}

model Student {
  id String @id @default(uuid())

  studentNumber String? @unique

  leadId String? @unique
  lead   Lead?   @relation(fields: [leadId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  counselorId String?

  counselor User? @relation("CounselorStudents", fields: [counselorId], references: [id])

  timeline StudentTimeline[]

  studentName  String
  mobileNumber String?
  emailId      String?
  dob          DateTime?

  // preferredCountry String?
  // preferredCourse  String?
  // intake           String?
  status StudentStatus @default(active)
  // visaStage        StudentVisaStage @default(APPLICATION_SUBMITTED)

  // passport                  String?
  // admissionDate             DateTime?
  // currentStage              Studentstage      @default(PURSUING)
  // englishWaiverType         EnglishWaiverType @default(NONE)
  // applicationType           ApplicationType   @default(BACHELOR)
  // immigrationPortalPassword String?
  // depositDeadline           DateTime?
  // casDeadline               DateTime?
  // universityStart           DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  // visaDetail     VisaDetail?
  // remarks        Remark[]
  applications  Application[]
  loanInquiries LoanInquiry[]
  // studentCourses StudentCourses[]
  // docs           Doc[]

  @@index([branchId])
  @@index([counselorId])
}

model Doc {
  id String @id @default(uuid())

  name    String?
  address String
  type    String?

  // studentId String?
  // student   Student? @relation(fields: [studentId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StudentcoursesStatus {
  DRAFT
  APPLIED
  PENDING
  OFFER_RECEIVED
  PRIORITY_OFFER_RECEIVED
  CONDITIONAL_OFFER
  UNCONDITIONAL_OFFER
  REJECTED
  DEFERRED
}

model StudentCourses {
  id String @id @default(uuid())

  universityName    String
  courseName        String
  immigrationPortal String
  applicationDate   DateTime
  applicationStatus StudentcoursesStatus @default(PENDING)

  // studentId String
  // student   Student @relation(fields: [studentId], references: [id])
  leadId String? @unique
  lead   Lead?   @relation(fields: [leadId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id String @id @default(uuid())

  name String @unique
  code String @unique

  email String?
  phone String?

  city  String?
  state String?

  country String?
  pincode String?

  address String?

  status Boolean @default(true)

  users     User[]
  leads     Lead[]
  mbbsLeads MbbsLead[]
  students  Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TimelineType {
  note
  followup
  call
  meeting

  status_change

  document
  application
  offer_letter

  loan
  visa

  payment

  system
}

model StudentTimeline {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  type TimelineType

  title String

  description String? @db.Text

  followupDate DateTime?

  oldValue String?
  newValue String?

  createdById String?

  createdBy User? @relation("StudentTimelineCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([studentId, createdAt])
}

model Country {
  id String @id @default(uuid())

  name String @unique

  code String @unique // AU, US, UK, CA

  currency String?

  universities University[]

  status Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Intake {
  id String @id @default(uuid())

  name String @unique
  status Boolean @default(true)
  
  courses UniversityCourse[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadSource {
  id String @id @default(uuid())

  name String @unique

  status Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadDegree {
  id String @id @default(uuid())

  name String @unique

  status Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadUniversity {
  id String @id @default(uuid())

  name String @unique

  status Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Tier {
  T1
  T2
  T3
  T4
}

model University {
  id String @id @default(uuid())

  name      String
  tier      Tier    @default(T1)
  countryId String
  country   Country @relation(fields: [countryId], references: [id])

  logo String?

  website String?

  address    String?
  city       String?
  state      String?
  postalCode String?

  ranking Int?

  establishedYear Int?

  applicationFee Decimal? @db.Decimal(12, 2)

  currency String? // USD, AUD, GBP, CAD

  description String? @db.Text

  status UniversityStatus @default(active)

  courses      UniversityCourse[]
  scholarships UniversityScholarship[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contactPerson String?
  contactEmail  String?
  contactPhone  String?
  intakeNotes   String?

  @@unique([name, countryId])
  @@index([countryId])
  @@index([countryId, city])
  @@index([name])
  @@index([city])
  @@index([status])
}

enum DegreeType {
  diploma
  bachelors
  masters
  phd
  mba
  certificate
}

model UniversityCourse {
  id                  String                  @id @default(uuid())
  name                String
  degree              DegreeType
  durationMonths      Int?
  annualTuitionFee    Decimal?                @db.Decimal(12, 2)
  totalTuitionFee     Decimal?                @db.Decimal(12, 2)
  currency            String?
  intakeId            String?
  intake              Intake?                 @relation(fields: [intakeId], references: [id])
  minimumPercentage   Float?
  backlogLimit        Int?
  englishRequirement  String?
  ieltsOverall        Float?
  ieltsListening      Float?
  ieltsReading        Float?
  ieltsWriting        Float?
  ieltsSpeaking       Float?
  greRequired         Boolean                 @default(false)
  gmatRequired        Boolean                 @default(false)
  courseCode          String?
  description         String?                 @db.Text
  applicationDeadline DateTime?
  status              Boolean                 @default(true)
  scholarships        UniversityScholarship[]

  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([universityId])
}

enum UniversityStatus {
  active
  inactive
  archived
}

model UniversityScholarship {
  id String @id @default(uuid())

  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  name String

  amount Decimal? @db.Decimal(12, 2)

  percentage Float?

  description String? @db.Text

  status    UniversityStatus  @default(active)
  courseId  String?
  course    UniversityCourse? @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([universityId])
  @@index([courseId])
}
